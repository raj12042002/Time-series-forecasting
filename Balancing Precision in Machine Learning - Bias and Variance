# Radix Sort

```python
def counting(arr,exp):

    n=len(arr)

    output=[0]*n

    count=[0]*10

    for i in arr:
        index=i//exp
        count[index%10]+=1

    for i in range(1,10):
        count[i]+=count[i-1]

    i=n-1

    while i>=0:
        index=arr[i]//exp
        output[count[index%10]-1]=arr[i]
        count[index%10]-=1
        i-=1

    for i in range(n):
        arr[i]=output[i]

def radix_sort(arr):

    max1=max(arr)

    exp=1

    while max1//exp>0:
        counting(arr,exp)
        exp*=10

arr=[170,45,75,90]

radix_sort(arr)

print(arr)
```

